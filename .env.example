# ══════════════════════════════════════════════════════════════════════════════
# AI Data Platform — Environment Configuration
#
# Copy to .env and fill in values before running `make up`.
# NEVER commit .env to git. Only .env.example is committed.
# ══════════════════════════════════════════════════════════════════════════════

# ── MinIO (S3-compatible local storage) ───────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
MINIO_ENDPOINT=http://minio:9000

# ── Redis (Celery broker) ─────────────────────────────────────────────────────
# PRODUCTION: set a strong password here and in your secrets manager.
# The broker URL in docker-compose.yml is: redis://:${REDIS_PASSWORD}@redis:6379/0
# An empty password means unauthenticated access — acceptable only on a
# private Docker network with no external exposure. Never leave empty on a
# host with a public interface.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
# 3-broker cluster — all must be reachable from producer/consumer containers
KAFKA_BOOTSTRAP_SERVERS=kafka-1:29092,kafka-2:29093,kafka-3:29094

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_PACKAGES=io.delta:delta-spark_2.12:3.1.0,org.apache.hadoop:hadoop-aws:3.3.4,com.amazonaws:aws-java-sdk-bundle:1.12.262

# ── Postgres (Airflow metadata DB) ────────────────────────────────────────────
POSTGRES_PASSWORD=airflow

# ── Airflow ───────────────────────────────────────────────────────────────────
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# `make up` auto-generates this if left as REPLACE_WITH_GENERATED_KEY
AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_GENERATED_KEY

# Generate webserver secret: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_UID=50000

# ── Data paths (inside containers) ───────────────────────────────────────────
DATA_BRONZE_PATH=s3a://bronze
DATA_SILVER_PATH=s3a://silver
DATA_GOLD_PATH=s3a://gold
DATA_CHECKPOINT_PATH=s3a://checkpoints

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000
