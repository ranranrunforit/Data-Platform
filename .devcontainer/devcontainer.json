{
  "name": "AI Data Platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  // Copy .env before any docker compose commands so compose validation succeeds.
  // Python deps needed for `make generate` are installed here too.
  "postCreateCommand": "cp -n .env.example .env 2>/dev/null || true && pip install --quiet numpy pandas faker cryptography dbt-duckdb==1.7.4 great-expectations==0.18.19",

  "forwardPorts": [8000, 8080, 8081, 8082, 5555, 9000, 9001],

  "portsAttributes": {
    "8000": { "label": "API (FastAPI)" },
    "8080": { "label": "Spark Master UI" },
    "8081": { "label": "Airflow UI" },
    "8082": { "label": "Kafka UI" },
    "5555": { "label": "Flower (Celery)" },
    "9000": { "label": "MinIO API" },
    "9001": { "label": "MinIO Console" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "innoverio.vscode-dbt-power-user",
        "hashicorp.terraform",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
