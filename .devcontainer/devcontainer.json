{
  "name": "AI Data Platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  // Install Docker CLI (talks to host daemon via mounted socket) + Python deps.
  // No Docker daemon runs inside the container — the host Codespaces VM provides it.
  "postCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y -qq docker.io docker-compose-v2 && sudo chmod 666 /var/run/docker.sock && cp -n .env.example .env 2>/dev/null || true && pip install --quiet numpy pandas faker cryptography dbt-duckdb==1.7.4 great-expectations==0.18.19",

  "forwardPorts": [8000, 8080, 8081, 8082, 5555, 9000, 9001],

  "portsAttributes": {
    "8000": { "label": "API (FastAPI)" },
    "8080": { "label": "Spark Master UI" },
    "8081": { "label": "Airflow UI" },
    "8082": { "label": "Kafka UI" },
    "5555": { "label": "Flower (Celery)" },
    "9000": { "label": "MinIO API" },
    "9001": { "label": "MinIO Console" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "innoverio.vscode-dbt-power-user",
        "hashicorp.terraform",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
